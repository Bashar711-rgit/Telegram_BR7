        "max": 0.4,
        "action": "ignore"
      },
      "review": {
        "min": 0.4,
        "max": 0.65,
        "action": "review"
      },
      "accept": {
        "min": 0.65,
        "max": 1.0,
        "action": "accept"
      }
    },
    "scoring_modules": {
      "intent_score": "Verb-object presence, quality, and combination",
      "academic_score": "Domain relevance of detected objects (phrase vs single word weighted)",
      "grammar_score": "First-person subject, proper request structure",
      "distance_score": "Token proximity between intent verb and academic object",
      "urgency_score": "Time-pressure signals",
      "context_score": "University environment signals",
      "negation_score": "Reduces positive scores when negation scope is active",
      "advert_score": "Advertisement probability – suppresses confidence when high"
    },
    "total_unique_entries": "optimized",
    "v13_changes": [
      "Dialect mapping only converts non-canonical variants; base verbs like 'ابغى' remain in lexicon",
      "Subject markers: first-person plural verbs moved to weak_provider; require 2+ commercial signals",
