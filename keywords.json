    "engine_compatibility": "filter_engine.py v13.0+ / IntentEngine-NLP",
    "architecture": "NLP Pipeline — Tokenization → Entity Extraction → Negation Analysis → Dependency Analysis → Distance Scoring → Ad Detection → Confidence Engine → Explainability",
    "pipeline_stages": [
      "1. pre_processing — Unicode normalization, Arabic char normalization, tashkeel removal, obfuscation normalization",
      "2. tokenization — Word tokenization with position tracking",
      "3. normalization — Dialect mapping (canonical base forms only), clitic stripping, fuzzy matching (min 5 chars, academic objects only)",
      "4. entity_extraction — Intent verbs, academic objects, negation markers, subjects, prices, URLs, implicit requests",
      "5. negation_analysis — Clause-based scope detection (no 'و' boundary), exception handling, resolution phrase detection",
      "6. dependency_analysis — Subject person detection, verb-object binding, request vs offer, signal priority",
      "7. distance_analysis — Token distance between intent verb and academic object, length modifier",
      "8. ad_detection — Contextual advertisement classification with provider confidence (weak provider needs 2+ signals), individual provider detection",
      "9. scoring_engine — Independent module scores combined into confidence, length modifier applied, phrase vs single word weighting",
      "10. decision_engine — ignore / review / accept with explainability reasons, high-confidence boost patterns"
    ],
    "design_principles": [
      "Every lexicon entry has ONE canonical form – variants handled via dialect_mapping",
      "Signal priority: phrase_match > entity_match > single_token_match",
      "Scoring weights configurable; phrase matches get higher weight than single words",
      "Ad detection: first-person plural/individual verbs require 2+ commercial signals unless explicitly provider language (ليكم / معاكم)",
      "Negation is clause-based with explicit boundaries (excluding 'و'); recovery patterns for exceptions",
      "Token distance modifies score; message length modifies confidence (short but clear requests still get fair weight)",
      "Subject markers use non-verbal pronouns only; verbs belong to intent/action categories",
      "Implicit requests require an academic object/context present",
      "Obfuscation normalization applied early",
      "Fuzzy matching restricted to academic objects with min length 5 and similarity threshold awareness",
      "Explainability mandatory; hard rules limited to high-confidence boost only (no bypass)",
      "English academic terms receive lower weight unless accompanied by Arabic intent verb",
      "Auto-learning disabled; human approval required for feedback integration"
    ],
    "arabic_normalization": {
      "char_map": {
        "أ": "ا",
        "إ": "ا",
        "آ": "ا",
        "ة": "ه",
        "ى": "ي",
        "ئ": "ي",
        "ؤ": "و"
      },
      "remove": [
        "tashkeel",
        "tatweel"
      ],
      "note": "All entries in this file are written POST-normalization"
    },
    "obfuscation_normalization": {
      "remove_spaces_inside_words": true,
      "remove_zero_width_chars": true,
      "normalize_repeated_letters": true
    },
    "fuzzy_matching": {
      "enabled": true,
      "max_edit_distance": 1,
      "minimum_token_length": 5,
      "only_for": [
        "academic_objects"
      ],
      "similarity_note": "Engine should also consider token similarity (e.g., >0.92) and context to avoid false positives with similar roots"
    },
    "signal_priority": {
      "phrase_match": 3,
      "entity_match": 2,
      "single_token_match": 1
    },
    "confidence_thresholds": {
      "ignore": {
